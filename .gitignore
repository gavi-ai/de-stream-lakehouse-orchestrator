# ==========================================
# Gavi's Jatt 2.0 Enterprise DE Filter
# ==========================================

# Local Python Virtual Environment (Sabs bada package filter)
de_env/
venv/
.venv/
env/

# Python caching patterns
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# dbt Logs, targets, and local user profiles
logs/
target/
dbt_modules/
dbt_packages/
# CRITICAL: Local profiles lock out (Never leak connection configurations!)
profiles.yml

# OS specific temporary files (Mac special junk codes)
.DS_Store
.AppleDouble
.LSOverride
Thunbs.db

# Local environment variables keys
.env
.env.local
# Terraform local state and binaries cache block
.terraform/
terraform/.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl